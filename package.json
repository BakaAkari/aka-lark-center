{
  "name": "koishi-plugin-aka-lark-center",
  "version": "0.6.0-beta.4",
  "description": "Koishi Lark/Feishu LLM tool gateway powered by self-managed lark-cli binary.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BakaAkari/aka-lark-center.git"
  },
  "homepage": "https://github.com/BakaAkari/aka-lark-center#readme",
  "bugs": {
    "url": "https://github.com/BakaAkari/aka-lark-center/issues"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/cli/checksums.txt"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "koishi": "^4.18.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.5.2",
    "koishi": "^4.18.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "koishi",
    "koishi-plugin",
    "lark",
    "feishu",
    "lark-cli",
    "larksuite-cli",
    "feishu",
    "chatluna",
    "llm-tools",
    "openapi",
    "bot"
  ],
  "koishi": {
    "description": {
      "en": "Use Lark/Feishu via bundled official CLI from Koishi, with ChatLuna tool integration.",
      "zh": "通过内置官方 CLI 在 Koishi 中使用飞书/Lark，支持 ChatLuna 工具集成。"
    },
    "category": "tool",
    "locales": [
      "zh",
      "en"
    ]
  }
}
